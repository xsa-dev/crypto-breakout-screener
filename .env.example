# Пример .env. Скопируй в `.env` и заполни значения. `.env` не коммитится.

# Путь к файлу SQLite-БД (локально — рядом с проектом; на VPS — `/var/lib/tradebot/app.db`).
DB_PATH=app.db

# Пароль для веб-админки (одно поле, без логина).
ADMIN_PASSWORD=changeme

# Секрет для подписи cookie-сессии админки (любая длинная случайная строка).
ADMIN_SESSION_SECRET=changeme-please-generate-random

# Ключи Bybit API (право Futures Trade). Без них робот не торгует, только показывает сигналы.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Telegram-бот для алертов: токен из @BotFather и id чата (для каналов — со знаком минус).
TG_BOT_TOKEN=
TG_CHAT_ID=
